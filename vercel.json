{
  "version": 2,
  "rewrites": [
    { "source": "/api/tiktok/status/:publishId", "destination": "/api/tiktok/status/[publishId]" },
    { "source": "/api/shorts/:channelId", "destination": "/api/shorts/[channelId]" },
    { "source": "/api/download/:videoId", "destination": "/api/download/[videoId]" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ]
}
